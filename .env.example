# ============================================
# 🔐 Variables d'Environnement - Docker Compose
# ============================================

# 🌐 DOMAINE
DOMAIN=votre-portfolio.com
ENVIRONMENT=Production

# 🗄️ SQL SERVER
SQL_SA_PASSWORD=YourStrong@Password123!Secure2026
MSSQL_DATA_DIR=/var/opt/mssql/data

# 🔴 REDIS
REDIS_PASSWORD=redis_secure_password_123_change_me!

# 🔑 JWT SECRETS
JWT_SECRET_KEY=YourSuperSecretKeyForJWT2026!@#$%^&*()_+-=[]{}|;:',.<>?/VeryLongAndSecure

# 📧 SMTP (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=votre-email@gmail.com
SMTP_PASSWORD=votre-mot-de-passe-app

# 🎓 CORS
CORS_ALLOWED_ORIGINS=https://votre-portfolio.com,https://www.votre-portfolio.com,http://localhost:4200

# 🤖 OLLAMA
OLLAMA_MODEL=mistral

# 📊 LOGGING
LOG_LEVEL=Information
